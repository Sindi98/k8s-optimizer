# ──────────────────────────────────────────────────────────────────────────
# Kube Optimizer — configurazione (copiare in .env)
#
# Queste variabili sono i DEFAULT di avvio. Tutto è poi modificabile a caldo
# dalla UI ("⚙ Configura"): provider LLM, modello, chiavi, endpoint Prometheus,
# finestra e soglie. Gli override della UI vengono salvati in CONFIG_PATH e
# hanno la precedenza su queste variabili.
# ──────────────────────────────────────────────────────────────────────────

# Modalità demo: nessun cluster, nessun Prometheus, dati sintetici.
# Mettere a "false" per analizzare un cluster reale.
DEMO_MODE=true

# File JSON dove vengono persistite le modifiche fatte dalla UI.
# In locale, vuoto = file temporaneo. In-cluster va su un volume (vedi k8s/).
# CONFIG_PATH=/data/config.json

# ── Connessione al cluster ────────────────────────────────────────────────
# true se l'app gira dentro il cluster (usa il ServiceAccount montato).
IN_CLUSTER=false
# Path al kubeconfig quando si esegue in locale (vuoto = ~/.kube/config).
# KUBECONFIG=/Users/sindi/.kube/config

# ── Prometheus ─────────────────────────────────────────────────────────────
# In locale puoi fare: kubectl port-forward svc/prometheus 9090:9090
PROMETHEUS_URL=http://localhost:9090
# Finestra di analisi (es. 24h, 3d, 7d, 14d).
ANALYSIS_WINDOW=7d
PROM_TIMEOUT=30

# ── Modello AI per i report ────────────────────────────────────────────────
# Provider: mock | anthropic | ollama | openai
#   mock      → report generato localmente, senza chiamate esterne (default)
#   ollama    → modello locale, nessun dato esce dal cluster
#   anthropic → Claude (richiede pip install anthropic)
#   openai    → OpenAI (richiede pip install openai)
LLM_PROVIDER=mock
REPORT_LANGUAGE=it

# anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ollama
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# ── Soglie di analisi (opzionali, valori di default mostrati) ───────────────
# Sotto questa frazione di utilizzo (p95/richiesta) il container è sovradimensionato.
# OVERPROV_RATIO=0.5
# Buffer sopra il p95 osservato per la richiesta consigliata.
# REQUEST_BUFFER=1.2
# Buffer sopra il max osservato per il limite consigliato.
# LIMIT_BUFFER=1.5
# Sopra questa frazione del limite (max) si segnala rischio OOM / under-provisioning.
# RISK_RATIO=0.9
# Throttling CPU oltre questa frazione viene segnalato.
# THROTTLE_RATIO=0.25
# Sotto questo uso CPU (core, p95) e memoria quasi nulla il pod è "inattivo".
# IDLE_CPU_CORES=0.005
# Sotto questo uso di memoria (byte, p95) e CPU quasi nulla il pod è "inattivo" (default 32Mi).
# IDLE_MEM_BYTES=33554432

# ── Sicurezza ───────────────────────────────────────────────────────────────
# Origini cross-origin ammesse (lista separata da virgole). Vuoto = solo
# same-origin: l'app serve già la propria dashboard, quindi di norma non serve.
# Impostare solo se la UI è ospitata su un'origine diversa dall'API.
# CORS_ALLOW_ORIGINS=https://dashboard.example.com
